<!DOCTYPE html>
<html lang="th">
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>QA/QC Data Collector</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/html5-qrcode"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  
  <style>
    body { font-family: 'Prompt', sans-serif; background-color: #F5F6F8; color: #333; }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    .meat-texture { background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.4'/%3E%3C/svg%3E"); }
    .viewfinder-mask { box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.65); }
    @media print { .no-print, header { display: none !important; } body { background-color: white; } .shadow-sm { box-shadow: none !important; } }
  </style>
</head>
<body class="pb-10">

  <header class="bg-[#1C1C1C] text-white px-4 py-2 sticky top-0 z-40 flex justify-between items-center shadow-md border-b-2 border-[#E32A26]">
    <div class="flex items-center gap-3">
      <div class="bg-white rounded-full p-1.5 h-10 w-10 flex items-center justify-center border-2 border-[#E32A26]">
        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/cd/CP_logo.svg/1024px-CP_logo.svg.png" alt="CP" class="w-full object-contain">
      </div>
      <div>
        <h1 class="text-[14px] md:text-lg font-bold leading-tight">ระบบเก็บข้อมูลคุณภาพเนื้อหมู (QA/QC)</h1>
        <p class="text-[10px] md:text-xs text-gray-400">Data Collection for AI Training</p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <button id="sync-btn" onclick="syncOfflineData()" class="hidden items-center gap-1 bg-orange-500 text-white px-2 py-1.5 rounded text-[10px] font-bold shadow-sm">
        <i class="fa-solid fa-cloud-arrow-up"></i> ซิงก์ (<span id="offline-count">0</span>)
      </button>
      <div id="network-status" class="hidden md:flex items-center gap-1 px-2 py-1.5 rounded bg-green-500 text-white text-[10px] font-bold">
        <i class="fa-solid fa-wifi"></i> Online
      </div>
    </div>
  </header>

  <main id="main-content" class="max-w-[1240px] mx-auto p-2 md:p-4 space-y-4">
    
    <div class="bg-white rounded-xl shadow-sm border border-[#E32A26]/30 overflow-hidden relative no-print">
      <div class="p-4 bg-gradient-to-b from-gray-50 to-white">
        <div class="flex overflow-x-auto gap-2 md:gap-4 pb-2 scrollbar-hide justify-between items-end" id="standard-discs-container"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
      
      <div class="lg:col-span-4 flex flex-col gap-4 no-print">
        
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
          <h2 class="font-bold text-[14px] text-gray-800 mb-2 flex items-center gap-2"><span class="bg-black text-white w-5 h-5 rounded-full flex items-center justify-center text-[10px]">1</span> สแกน QR ล็อตผลิต</h2>
          <button onclick="toggleQRScanner()" id="btn-toggle-qr" class="w-full bg-blue-50 text-blue-600 border border-blue-200 py-2 rounded-lg text-xs font-bold mb-3 flex justify-center items-center gap-2">
             <i class="fa-solid fa-qrcode"></i> เปิดกล้องสแกน QR Code
          </button>
          <input type="file" id="qr-file-input" accept="image/*" capture="environment" class="hidden" onchange="handleQRFileUpload(event)">
          <div id="qr-reader-container" class="hidden mb-3 overflow-hidden rounded-lg border"><div id="qr-reader" class="w-full"></div></div>
          <input type="text" id="inp-lot" placeholder="รหัสล็อตสินค้า..." class="w-full border border-gray-300 rounded-lg p-2 text-sm outline-none focus:border-[#E32A26] bg-gray-50 font-mono text-center font-bold text-gray-700" />
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
          <h2 class="font-bold text-[14px] text-gray-800 mb-3 flex items-center gap-2"><span class="bg-black text-white w-5 h-5 rounded-full flex items-center justify-center text-[10px]">2</span> วัดค่าสีเนื้อหน้างาน</h2>
          
          <div class="flex gap-1 mb-4 bg-gray-100 p-1 rounded-lg">
            <button onclick="setMode('camera')" id="tab-camera" class="flex-1 py-1.5 text-[11px] font-bold rounded-md bg-[#E32A26] text-white shadow-sm flex items-center justify-center gap-1"><i class="fa-solid fa-camera"></i> ถ่ายภาพ</button>
            <button onclick="setMode('upload')" id="tab-upload" class="flex-1 py-1.5 text-[11px] font-bold rounded-md text-gray-600 flex items-center justify-center gap-1"><i class="fa-solid fa-upload"></i> อัปโหลด</button>
          </div>

          <div id="media-area" class="border border-gray-300 rounded-lg flex flex-col items-center justify-center bg-black mb-4 relative h-64 overflow-hidden cursor-pointer shadow-inner">
            <div id="analyzing-loader" class="hidden absolute inset-0 z-40 bg-white/80 flex flex-col items-center justify-center backdrop-blur-sm">
              <div class="animate-spin rounded-full h-8 w-8 border-4 border-[#E32A26] border-t-transparent mb-2"></div>
              <p class="text-xs font-bold text-[#E32A26]">AI กำลังสกัดค่าสี...</p>
            </div>
            
            <video id="video-feed" autoplay playsinline class="hidden absolute inset-0 w-full h-full object-cover z-0"></video>
            <img id="photo-preview" class="hidden absolute inset-0 w-full h-full object-cover z-10" />
            <canvas id="canvas-capture" class="hidden"></canvas>
            
            <div id="target-frame" class="hidden absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-40 h-40 pointer-events-none z-20 flex flex-col items-center justify-center">
              <div class="absolute inset-0 rounded-lg viewfinder-mask"></div>
              <div class="absolute top-0 left-0 w-8 h-8 border-t-4 border-l-4 border-[#E32A26] rounded-tl-lg z-30"></div>
              <div class="absolute top-0 right-0 w-8 h-8 border-t-4 border-r-4 border-[#E32A26] rounded-tr-lg z-30"></div>
              <div class="absolute bottom-0 left-0 w-8 h-8 border-b-4 border-l-4 border-[#E32A26] rounded-bl-lg z-30"></div>
              <div class="absolute bottom-0 right-0 w-8 h-8 border-b-4 border-r-4 border-[#E32A26] rounded-br-lg z-30"></div>
              <i class="fa-solid fa-plus text-[#E32A26]/50 text-xl z-30"></i>
              <div class="absolute -bottom-14 whitespace-nowrap text-white text-[11px] font-bold drop-shadow-md z-30 flex flex-col items-center w-[200px]">
                <p class="bg-black/50 px-3 py-1 rounded-full"><i class="fa-solid fa-expand"></i> จัดชิ้นเนื้อให้อยู่ในกรอบ</p>
              </div>
            </div>

            <div id="upload-placeholder" class="hidden flex-col items-center justify-center w-full h-full bg-gray-50 border-2 border-dashed border-gray-300 z-30">
              <i class="fa-solid fa-cloud-arrow-up text-3xl text-gray-400 mb-2"></i>
              <span class="text-[13px] font-medium text-gray-600">คลิกหรือลากรูปภาพมาวาง</span>
              <input type="file" id="file-input" class="hidden" accept="image/*" onchange="handleFileUpload(event)">
            </div>
            
            <div id="camera-fallback" class="hidden flex-col items-center justify-center w-full h-full bg-gray-50 relative z-30 border-2 border-dashed border-gray-300">
               <label class="bg-[#E32A26] text-white px-5 py-2 rounded-full text-xs font-bold cursor-pointer hover:bg-red-700 shadow-md">
                 <i class="fa-solid fa-camera mr-1"></i> เปิดกล้องมือถือ
                 <input type="file" accept="image/*" capture="environment" class="hidden" onchange="handleFileUpload(event)">
               </label>
            </div>

            <button id="btn-capture" onclick="takePhoto()" class="hidden absolute bottom-4 bg-[#E32A26] text-white text-[14px] px-8 py-2.5 rounded-full shadow-[0_0_15px_rgba(227,42,38,0.5)] font-bold z-30 border-2 border-white"><i class="fa-solid fa-camera mr-1"></i> กดถ่ายภาพ</button>
            <button id="btn-clear-photo" onclick="clearPhoto()" class="hidden absolute top-2 right-2 bg-black/60 text-white w-8 h-8 rounded-full z-40 flex items-center justify-center"><i class="fa-solid fa-rotate-left"></i></button>
          </div>

          <label class="flex items-center gap-2 mb-4 bg-yellow-50 p-2 rounded border border-yellow-200 cursor-pointer">
            <input type="checkbox" id="chk-colorcard" class="w-4 h-4 text-[#E32A26] accent-[#E32A26]" checked>
            <span class="text-[11px] font-bold text-yellow-800"><i class="fa-solid fa-palette"></i> มีการวางแผ่นเทียบสี (Color Card) ในเฟรมภาพ</span>
          </label>

          <div class="grid grid-cols-3 gap-2 mb-4 opacity-70">
            <div class="border rounded-lg px-1 py-1 text-center bg-gray-50"><p class="text-[9px] font-bold text-gray-500">L*</p><input type="text" id="inp-L" value="0.0" readonly class="w-full text-center text-sm font-black mt-1 text-gray-700 bg-transparent outline-none" /></div>
            <div class="border rounded-lg px-1 py-1 text-center bg-gray-50"><p class="text-[9px] font-bold text-gray-500">a*</p><input type="text" id="inp-a" value="0.0" readonly class="w-full text-center text-sm font-black mt-1 text-gray-700 bg-transparent outline-none" /></div>
            <div class="border rounded-lg px-1 py-1 text-center bg-gray-50"><p class="text-[9px] font-bold text-gray-500">b*</p><input type="text" id="inp-b" value="0.0" readonly class="w-full text-center text-sm font-black mt-1 text-gray-700 bg-transparent outline-none" /></div>
          </div>

          <div class="grid grid-cols-2 gap-2 mb-3 border-t border-gray-100 pt-3">
            <div class="border rounded-lg px-2 py-2 text-center"><p class="text-[10px] font-bold text-gray-500">อุณหภูมิแกนกลาง (°C)</p><input type="number" step="0.1" id="inp-temp" placeholder="เช่น 4.0" class="w-full text-center text-lg font-black mt-1 text-[#E32A26] outline-none" /></div>
            <div class="border rounded-lg px-2 py-2 text-center"><p class="text-[10px] font-bold text-gray-500">ค่า pH</p><input type="number" step="0.1" id="inp-ph" placeholder="เช่น 5.8" class="w-full text-center text-lg font-black mt-1 text-gray-800 outline-none" /></div>
          </div>

          <p class="text-[11px] text-gray-600 mb-2 font-bold mt-2">ตรวจสอบประสาทสัมผัส</p>
          <div class="flex gap-2 mb-4">
            <button id="chk-odor" onclick="toggleSensoryCheck('odor')" class="flex-1 py-1.5 rounded-full text-[10px] font-bold border flex items-center justify-center gap-1 bg-green-50 border-green-200 text-green-700"><i class="fa-solid fa-check-circle"></i> กลิ่นปกติ</button>
            <button id="chk-texture" onclick="toggleSensoryCheck('texture')" class="flex-1 py-1.5 rounded-full text-[10px] font-bold border flex items-center justify-center gap-1 bg-green-50 border-green-200 text-green-700"><i class="fa-solid fa-check-circle"></i> เนื้อเด้ง</button>
            <button id="chk-wetness" onclick="toggleSensoryCheck('wetness')" class="flex-1 py-1.5 rounded-full text-[10px] font-bold border flex items-center justify-center gap-1 bg-green-50 border-green-200 text-green-700"><i class="fa-solid fa-check-circle"></i> ไม่เยิ้ม</button>
          </div>
          <input type="text" id="inp-note" placeholder="หมายเหตุ / ชิ้นส่วน..." class="w-full border border-gray-300 rounded-lg p-2 text-xs outline-none bg-gray-50" />
        </div>
      </div>

      <div class="lg:col-span-8 flex flex-col gap-4">
        
        <div class="bg-[#E32A26]/5 rounded-xl shadow-sm border-2 border-[#E32A26]/30 p-4 no-print relative overflow-hidden">
          <div class="absolute top-0 right-0 bg-[#E32A26] text-white text-[9px] font-bold px-2 py-1 rounded-bl-lg z-10"><i class="fa-solid fa-user-tie"></i> สำหรับพนักงาน QA ยืนยันผล</div>
          <h2 class="font-bold text-[14px] text-gray-800 mb-3"><span class="bg-black text-white w-5 h-5 rounded-full inline-flex items-center justify-center text-[10px] mr-1">3</span> ยืนยันระดับสีด้วยสายตา (Expert Label)</h2>
          <p class="text-[11px] text-gray-600 mb-3">AI ประเมินผลให้เบื้องต้น แต่เพื่อสร้าง Dataset ที่ดี กรุณาเลือก "ระดับสีที่แท้จริง" ที่คุณเห็นด้วยสายตาตัวเองอีกครั้ง</p>
          
          <div class="flex flex-wrap gap-2" id="expert-label-container">
             <button onclick="setExpertLabel(1)" id="btn-exp-1" class="flex-1 min-w-[45px] py-2 rounded border bg-white text-gray-600 font-bold text-sm shadow-sm">1</button>
             <button onclick="setExpertLabel(2)" id="btn-exp-2" class="flex-1 min-w-[45px] py-2 rounded border bg-white text-gray-600 font-bold text-sm shadow-sm">2</button>
             <button onclick="setExpertLabel(3)" id="btn-exp-3" class="flex-1 min-w-[45px] py-2 rounded border bg-white text-gray-600 font-bold text-sm shadow-sm">3</button>
             <button onclick="setExpertLabel(4)" id="btn-exp-4" class="flex-1 min-w-[45px] py-2 rounded border bg-white text-gray-600 font-bold text-sm shadow-sm">4</button>
             <button onclick="setExpertLabel(5)" id="btn-exp-5" class="flex-1 min-w-[45px] py-2 rounded border bg-white text-gray-600 font-bold text-sm shadow-sm">5</button>
             <button onclick="setExpertLabel(6)" id="btn-exp-6" class="flex-1 min-w-[45px] py-2 rounded border bg-white text-gray-600 font-bold text-sm shadow-sm">6</button>
          </div>
        </div>

        <div id="pdf-content-area" class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 flex-1 flex flex-col">
          <div class="flex justify-between items-center mb-4 border-b pb-2">
             <h2 class="font-bold text-[16px] text-[#E32A26] flex items-center gap-2"><i class="fa-solid fa-clipboard-check"></i> ผลประเมินคุณภาพ (AI Prediction)</h2>
          </div>
          <div id="result-container" class="flex-1 flex flex-col justify-between border rounded-2xl p-5 md:p-8 relative transition-colors bg-gray-50">
             <div class="flex-1 flex flex-col items-center justify-center text-gray-400 border-2 border-dashed border-gray-300 rounded-xl p-8 bg-white/50">
               <i class="fa-solid fa-crosshairs text-5xl mb-3 opacity-30"></i>
               <p class="font-medium text-sm text-center">รอรับภาพเพื่อวิเคราะห์</p>
             </div>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mt-4 no-print">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <button onclick="saveRecord()" id="btn-save" class="md:col-span-2 bg-[#10B981] text-white py-4 rounded-xl text-base font-bold flex items-center justify-center gap-2 shadow-lg transform active:scale-95">
          <i class="fa-solid fa-cloud-arrow-up text-xl"></i> บันทึกข้อมูลและอัปโหลดภาพลงระบบ
        </button>
        <button onclick="downloadPDF()" class="bg-[#3B82F6] text-white py-4 rounded-xl text-sm font-bold flex items-center justify-center gap-2 shadow-sm">
          <i class="fa-solid fa-file-pdf"></i> สรุป PDF
        </button>
      </div>
    </div>
  </main>

  <script>
    // --- Clock & Network ---
    setInterval(() => { const now = new Date(); document.getElementById('clock-date').innerText = now.toLocaleDateString('th-TH'); document.getElementById('clock-time').innerText = now.toLocaleTimeString('th-TH'); }, 1000);
    
    function updateNetworkStatus() {
        const badge = document.getElementById('network-status'); const syncBtn = document.getElementById('sync-btn');
        let offlineData = JSON.parse(localStorage.getItem('offlineQA') || '[]');
        if (navigator.onLine) {
            if(badge) badge.className = "hidden md:flex items-center gap-1 px-2 py-1.5 rounded bg-green-500 text-white text-[10px] font-bold shadow-sm", badge.innerHTML = '<i class="fa-solid fa-wifi"></i> Online';
            if (offlineData.length > 0 && syncBtn) syncBtn.style.display = 'flex', syncBtn.classList.replace('bg-gray-400', 'bg-orange-500'), document.getElementById('offline-count').innerText = offlineData.length;
            else if(syncBtn) syncBtn.style.display = 'none';
        } else {
            if(badge) badge.className = "hidden md:flex items-center gap-1 px-2 py-1.5 rounded bg-gray-500 text-white text-[10px] font-bold shadow-sm", badge.innerHTML = '<i class="fa-solid fa-plane"></i> Offline';
            if(syncBtn && offlineData.length > 0) syncBtn.style.display = 'flex', syncBtn.classList.replace('bg-orange-500', 'bg-gray-400'), document.getElementById('offline-count').innerText = offlineData.length;
        }
    }
    window.addEventListener('online', updateNetworkStatus); window.addEventListener('offline', updateNetworkStatus);

    // --- Sensory & Expert Labels ---
    let sensoryChecks = { odor: true, texture: true, wetness: true };
    function toggleSensoryCheck(type) {
        sensoryChecks[type] = !sensoryChecks[type];
        const btn = document.getElementById(`chk-${type}`);
        if(sensoryChecks[type]) btn.className = "flex-1 py-1.5 rounded-full text-[10px] font-bold border flex items-center justify-center gap-1 bg-green-50 border-green-200 text-green-700", btn.innerHTML = `<i class="fa-solid fa-check-circle"></i> ${type === 'odor' ? 'กลิ่นปกติ' : type === 'texture' ? 'เนื้อเด้ง' : 'ไม่เยิ้ม'}`;
        else btn.className = "flex-1 py-1.5 rounded-full text-[10px] font-bold border flex items-center justify-center gap-1 bg-red-50 border-red-200 text-red-700", btn.innerHTML = `<i class="fa-solid fa-times-circle"></i> ${type === 'odor' ? 'กลิ่นผิดปกติ' : type === 'texture' ? 'เนื้อเละ' : 'น้ำเยิ้ม'}`;
    }

    let expertLabelValue = null;
    function setExpertLabel(level) {
      expertLabelValue = level;
      for(let i=1; i<=6; i++) {
        const btn = document.getElementById(`btn-exp-${i}`);
        if(i === level) btn.className = `flex-1 min-w-[45px] py-2 rounded border-2 border-black font-black text-white text-lg shadow-inner ${level==1||level==6 ? 'bg-red-600' : level==2||level==5 ? 'bg-orange-500' : 'bg-green-600'}`;
        else btn.className = "flex-1 min-w-[45px] py-2 rounded border bg-white text-gray-400 font-bold text-sm shadow-sm";
      }
    }

    // --- Core Standards ---
    const standards = [
      { l: 1, c: '#DCA982', t: 'สีซีดมาก', e: '(Pale)', d: 'PSE / คัดทิ้ง', color: '#DC2626', bg: 'bg-red-100 text-red-800' },
      { l: 2, c: '#D68A6B', t: 'สีชมพูอ่อน', e: 'L* 54 - 58', d: 'พอรับได้', color: '#D97706', bg: 'bg-orange-100 text-orange-800' },
      { l: 3, c: '#C2674B', t: 'สีชมพู', e: 'L* 49 - 54', d: 'ขายดีที่สุด', color: '#65A30D', bg: 'bg-lime-100 text-lime-800' },
      { l: 4, c: '#A43B2A', t: 'ชมพูแดง', e: '(ดีที่สุด)', d: 'ขายดีที่สุด', color: '#16A34A', bg: 'bg-green-100 text-green-800', ideal: true },
      { l: 5, c: '#88221D', t: 'สีแดงเข้ม', e: 'L* 38 - 43', d: 'พอรับได้', color: '#D97706', bg: 'bg-orange-100 text-orange-800' },
      { l: 6, c: '#5C191A', t: 'แดงคล้ำมาก', e: 'L* < 38', d: 'DFD / คัดทิ้ง', color: '#991B1B', bg: 'bg-red-100 text-red-800' }
    ];

    function renderDiscs(activeLevel = null) {
      document.getElementById('standard-discs-container').innerHTML = standards.map(s => {
        const isActive = activeLevel === s.l;
        const fade = activeLevel && !isActive ? 'opacity-30 grayscale' : 'opacity-100';
        const border = isActive ? `ring-4 ring-[${s.color}] ring-offset-2 scale-110 z-10 shadow-xl` : '';
        return `
        <div class="flex-1 min-w-[85px] md:min-w-[100px] flex flex-col items-center relative transition-all duration-500 ${fade}">
          ${isActive ? `<div class="absolute -top-4 text-2xl animate-bounce" style="color:${s.color}"><i class="fa-solid fa-caret-down"></i></div>` : ''}
          <div class="bg-white border rounded-xl p-2 md:p-3 shadow-sm flex flex-col items-center w-full relative transition-all duration-300 ${border}">
            <div class="relative w-[60px] h-[60px] rounded-full mx-auto flex items-center justify-center shadow-md overflow-hidden">
              <div class="absolute inset-0" style="background-color: ${s.c};"></div>
              <span class="relative z-10 text-white font-bold text-xl drop-shadow-md">${s.l}</span>
            </div>
            <div class="text-center mt-2 w-full"><p class="text-[11px] font-bold" style="color: ${s.color}">${s.t}</p></div>
          </div>
        </div>
      `}).join('');
    }

    // --- Camera & AI ---
    let videoStream = null; let currentResult = null; let rawImageBase64 = null;

    function setMode(mode) {
      ['upload', 'camera', 'manual'].forEach(m => document.getElementById(`tab-${m}`).className = m===mode ? "flex-1 py-1.5 text-[11px] font-bold rounded-md bg-[#E32A26] text-white flex justify-center items-center gap-1" : "flex-1 py-1.5 text-[11px] font-bold rounded-md text-gray-600 flex justify-center items-center gap-1 hover:bg-gray-200");
      if(mode === 'camera') startCamera(); else stopCamera();
      document.getElementById('upload-placeholder').style.display = mode==='upload' ? 'flex' : 'none';
      if(mode==='upload') document.getElementById('media-area').onclick = () => document.getElementById('file-input').click();
      else document.getElementById('media-area').onclick = null;
    }

    async function startCamera() {
      try {
        videoStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment', width: { ideal: 1280 } } });
        document.getElementById('video-feed').srcObject = videoStream;
        document.getElementById('video-feed').style.display = 'block'; document.getElementById('btn-capture').style.display = 'block'; document.getElementById('target-frame').style.display = 'flex'; document.getElementById('camera-fallback').style.display = 'none';
      } catch (err) { 
        document.getElementById('video-feed').style.display = 'none'; document.getElementById('btn-capture').style.display = 'none'; document.getElementById('target-frame').style.display = 'none'; document.getElementById('camera-fallback').style.display = 'flex'; 
      }
    }
    function stopCamera() { if(videoStream) { videoStream.getTracks().forEach(t => t.stop()); videoStream = null; } }

    function takePhoto() {
      const v = document.getElementById('video-feed'); const c = document.getElementById('canvas-capture');
      c.width = v.videoWidth; c.height = v.videoHeight; c.getContext('2d').drawImage(v, 0, 0);
      processImage(c.toDataURL('image/jpeg', 0.8)); // ใช้ 0.8 เพื่อบีบอัดรูปไม่ให้โหลดนานเกินไปตอนเซฟ
    }
    function handleFileUpload(e) {
      if(e.target.files && e.target.files[0]) {
        const reader = new FileReader(); reader.onload = (ev) => processImage(ev.target.result); reader.readAsDataURL(e.target.files[0]);
      }
    }

    function processImage(src) {
      rawImageBase64 = src; // เก็บรูปไว้รออัปโหลดขึ้น Drive
      document.getElementById('photo-preview').src = src; document.getElementById('photo-preview').style.display = 'block';
      document.getElementById('btn-clear-photo').style.display = 'flex'; document.getElementById('target-frame').style.display = 'flex';
      document.getElementById('video-feed').style.display = 'none'; document.getElementById('btn-capture').style.display = 'none'; document.getElementById('upload-placeholder').style.display = 'none'; document.getElementById('camera-fallback').style.display = 'none';
      stopCamera();
      
      // Fake AI Extraction Delay
      document.getElementById('analyzing-loader').style.display = 'flex';
      setTimeout(() => {
        // Mock L*a*b* for now (Replace with actual pixel extraction if needed)
        const L = (45 + Math.random() * 10).toFixed(1);
        document.getElementById('inp-L').value = L; document.getElementById('inp-a').value = 12.5; document.getElementById('inp-b').value = 5.2;
        document.getElementById('analyzing-loader').style.display = 'none';
        
        let aiLevel = 4;
        if (L >= 58) aiLevel = 1; else if (L >= 54) aiLevel = 2; else if (L >= 49) aiLevel = 3; else if (L >= 43) aiLevel = 4; else if (L >= 38) aiLevel = 5; else aiLevel = 6;
        
        // Auto Set Expert Label to match AI initially
        setExpertLabel(aiLevel);
        evaluateQuality(L, 12.5, 5.2, aiLevel);
      }, 800);
    }

    function clearPhoto() {
      rawImageBase64 = null; expertLabelValue = null;
      document.getElementById('photo-preview').style.display = 'none'; document.getElementById('btn-clear-photo').style.display = 'none';
      setMode('camera');
    }

    function evaluateQuality(L, a, b, aiLevel) {
      let res = { L, a, b, level: aiLevel, acc: 98 };
      if (aiLevel == 1) res = {...res, title: "สีซีดมาก", engTitle: "Pale", subTitle: "ต่ำ (PSE)", score: 20, titleColor: "#DC2626", badgeColor: "bg-red-50 border-red-200", icon: '<i class="fa-solid fa-circle-xmark"></i>', actionText: "ไม่แนะนำขาย"};
      else if (aiLevel == 2) res = {...res, title: "สีชมพูอ่อน", engTitle: "Pale Pink", subTitle: "ต่ำกว่ามาตรฐาน", score: 65, titleColor: "#D97706", badgeColor: "bg-orange-50 border-orange-200", icon: '<i class="fa-solid fa-triangle-exclamation"></i>', actionText: "พอใช้"};
      else if (aiLevel == 3) res = {...res, title: "สีชมพู", engTitle: "Pink", subTitle: "คุณภาพดี", score: 85, titleColor: "#65A30D", badgeColor: "bg-lime-50 border-lime-200", icon: '<i class="fa-solid fa-circle-check"></i>', actionText: "ขายได้ปกติ"};
      else if (aiLevel == 4) res = {...res, title: "ชมพูแดง", engTitle: "Reddish Pink", subTitle: "ดีมาก (Ideal)", score: 98, titleColor: "#16A34A", badgeColor: "bg-green-50 border-green-200", icon: '<i class="fa-solid fa-star"></i>', actionText: "สดใหม่"};
      else if (aiLevel == 5) res = {...res, title: "สีแดงเข้ม", engTitle: "Dark Red", subTitle: "เริ่มแข็ง (DFD)", score: 65, titleColor: "#D97706", badgeColor: "bg-orange-50 border-orange-200", icon: '<i class="fa-solid fa-triangle-exclamation"></i>', actionText: "ยังขายได้"};
      else res = {...res, title: "แดงคล้ำมาก", engTitle: "Very Dark", subTitle: "ต่ำ (DFD)", score: 20, titleColor: "#991B1B", badgeColor: "bg-red-50 border-red-200", icon: '<i class="fa-solid fa-circle-xmark"></i>', actionText: "ไม่แนะนำขาย"};
      
      currentResult = res; renderResult(res); renderDiscs(res.level);
    }

    function renderResult(r) {
      document.getElementById('result-container').className = `flex-1 flex flex-col justify-between border rounded-2xl p-5 relative transition-colors ${r.badgeColor}`;
      document.getElementById('result-container').innerHTML = `
        <div class="flex items-center gap-6">
          <div class="w-24 h-24 rounded-full flex items-center justify-center text-5xl font-black text-white shadow-lg" style="background-color: ${r.titleColor}">${r.level}</div>
          <div>
            <h3 class="text-3xl font-black mb-1" style="color: ${r.titleColor}">${r.actionText}</h3>
            <p class="text-sm font-bold flex items-center gap-2 text-gray-700"><span style="color: ${r.titleColor}">${r.icon}</span> AI Prediction: ${r.subTitle}</p>
          </div>
        </div>
      `;
    }

    // --- Save Data (The Data Collection Core) ---
  const API_URL = "ใส่_WEB_APP_URL_ที่ลงท้ายด้วย_exec_ตรงนี้"; 

function saveRecord() {
  if(!currentResult) return alert("กรุณาถ่ายภาพและประเมินผลก่อนบันทึก");
  if(!expertLabelValue) return alert("⚠️ กรุณาระบุ 'ระดับสีจริงด้วยสายตา' (Expert Label)");
  if(!rawImageBase64) return alert("⚠️ ต้องมีรูปถ่ายเนื้อหมูเพื่อบันทึกเป็น Dataset ครับ");
  
  const btn = document.getElementById('btn-save');
  const originalHtml = btn.innerHTML;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-xl"></i> กำลังอัปโหลดภาพ...';
  btn.disabled = true;
  
  const payload = {
    ...currentResult,
    expertLevel: expertLabelValue,
    imageBase64: rawImageBase64,
    deviceInfo: navigator.userAgent.substring(0, 50),
    colorCardUsed: document.getElementById('chk-colorcard').checked,
    lotNumber: document.getElementById('inp-lot').value || '-',
    note: document.getElementById('inp-note').value || '-',
    temp: document.getElementById('inp-temp').value || '-',
    pH: document.getElementById('inp-ph').value || '-',
    odor: sensoryChecks.odor ? 'ปกติ' : 'ผิดปกติ',
    texture: sensoryChecks.texture ? 'เด้ง' : 'เละ',
    wetness: sensoryChecks.wetness ? 'ไม่เยิ้ม' : 'น้ำเยิ้ม',
    dateStr: new Date().toLocaleString('th-TH'),
    user: "QA-Expert"
  };

  if (navigator.onLine) {
      // 🚀 ตรงนี้คือส่วนที่เปลี่ยนไป ใช้ fetch ยิง API แทน
      fetch(API_URL, {
        method: 'POST',
        redirect: 'follow', // จำเป็นมากสำหรับ Google Apps Script
        // ใช้ text/plain เพื่อหลบระบบป้องกัน CORS ของ Browser
        headers: { 'Content-Type': 'text/plain;charset=utf-8' }, 
        body: JSON.stringify(payload)
      })
      .then(response => response.json())
      .then(res => {
          btn.innerHTML = originalHtml; btn.disabled = false;
          if(res.success) { 
            alert("✅ เก็บข้อมูลเข้า Dataset สำเร็จ!"); 
            clearPhoto(); 
          } else {
            alert("❌ Error: " + res.message);
          }
      })
      .catch(err => {
          btn.innerHTML = originalHtml; btn.disabled = false;
          alert("❌ ส่งข้อมูลไม่สำเร็จ ตรวจสอบอินเทอร์เน็ต: " + err);
      });
  } else {
      // Offline mode เหมือนเดิม
      let offlineData = JSON.parse(localStorage.getItem('offlineQA') || '[]');
      offlineData.push(payload); localStorage.setItem('offlineQA', JSON.stringify(offlineData));
      btn.innerHTML = originalHtml; btn.disabled = false;
      alert("📱 บันทึกข้อมูลลงเครื่องชั่วคราวแล้ว (Offline Mode)");
      clearPhoto(); updateNetworkStatus();
  }
}

    // --- QR Code ---
    let html5QrCode = null;
    function toggleQRScanner() {
      const c = document.getElementById('qr-reader-container'); const b = document.getElementById('btn-toggle-qr');
      if(c.style.display === 'block') {
        html5QrCode.stop().then(()=>{ c.style.display='none'; b.innerHTML='<i class="fa-solid fa-qrcode"></i> เปิดกล้องสแกน QR Code'; b.className='w-full bg-blue-50 text-blue-600 border border-blue-200 py-2 rounded-lg text-xs font-bold mb-3 flex justify-center items-center gap-2'; });
      } else {
        c.style.display = 'block'; b.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>...';
        if (!html5QrCode) html5QrCode = new Html5Qrcode("qr-reader");
        html5QrCode.start({ facingMode: "environment" }, { fps: 10, qrbox: { width: 250, height: 250 } }, 
          (text) => { document.getElementById('inp-lot').value = text; toggleQRScanner(); },
          (err) => {}
        ).then(()=>{ b.innerHTML='<i class="fa-solid fa-times"></i> ปิดกล้องสแกน'; b.className='w-full bg-red-50 text-red-600 border border-red-200 py-2 rounded-lg text-xs font-bold mb-3 flex justify-center items-center gap-2'; })
        .catch(()=>{ document.getElementById('qr-file-input').click(); c.style.display='none'; b.innerHTML='<i class="fa-solid fa-qrcode"></i> เปิดกล้องสแกน QR Code'; });
      }
    }
    function handleQRFileUpload(e) {
      if (!html5QrCode) html5QrCode = new Html5Qrcode("qr-reader");
      html5QrCode.scanFile(e.target.files[0], true).then(text => { document.getElementById('inp-lot').value = text; alert("อ่านสำเร็จ"); }).catch(() => alert("ไม่พบ QR Code"));
    }

    window.onload = () => { renderDiscs(); setMode('camera'); updateNetworkStatus(); };
  </script>
